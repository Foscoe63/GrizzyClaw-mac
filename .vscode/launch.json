{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "sweetpad-lldb",
            "request": "launch",
            "name": "Build and Launch (SweetPad)",
            "preLaunchTask": "sweetpad: launch",
            "stopAll": true
        },
        {
            "type": "sweetpad-lldb",
            "request": "attach",
            "name": "Attach to Running App (SweetPad)",
            "description": "Use this if the app is already running to avoid rebuild"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:GrizzyClaw-mac}",
            "name": "Debug GrizzyClaw",
            "target": "GrizzyClaw",
            "configuration": "debug",
            "preLaunchTask": "swift: Build Debug GrizzyClaw"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:GrizzyClaw-mac}",
            "name": "Release GrizzyClaw",
            "target": "GrizzyClaw",
            "configuration": "release",
            "preLaunchTask": "swift: Build Release GrizzyClaw"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:GrizzyClaw-mac}",
            "name": "Debug GrizzyClawCLI",
            "target": "GrizzyClawCLI",
            "configuration": "debug",
            "preLaunchTask": "swift: Build Debug GrizzyClawCLI"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:GrizzyClaw-mac}",
            "name": "Release GrizzyClawCLI",
            "target": "GrizzyClawCLI",
            "configuration": "release",
            "preLaunchTask": "swift: Build Release GrizzyClawCLI"
        }
    ]
}